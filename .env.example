# Authentication
AUTH_MODE=max              # "max" (Agent SDK, no API key) or "api_key" (pay-as-you-go)
ANTHROPIC_API_KEY=         # Required if AUTH_MODE=api_key

# OpenAI (embeddings only)
OPENAI_API_KEY=sk-...

# Models
MODEL_MAIN=sonnet
MODEL_TRIAGE=haiku
MODEL_REFLECTION=haiku
MODEL_COMPACTION=sonnet
MODEL_ESCALATION=opus
ESCALATION_EFFORT=high     # low, medium, high, max

# Tools (optional). When the corresponding env var is set, the LLM
# gains the matching tool — registered as an in-process MCP server
# and exposed as `mcp__microwave__<tool-name>`. Without the key the
# tool isn't advertised to the model.

# Instacart Developer Platform — `instacart_create_cart` tool. Builds
# a Shop with Instacart link from a list of items; user finishes
# checkout in Instacart. Get a key at developer.instacart.com.
INSTACART_API_KEY=
# Optional: where to send the user after Instacart checkout.
# INSTACART_PARTNER_LINKBACK_URL=https://your.site/thanks

# Native web tools (Phase C.4). webfetch is always registered (no API
# key needed). Set this to "true" / "1" to disable, e.g. for sandboxed
# CI or tests that must not reach the network.
# WEB_TOOLS_DISABLED=

# GitHub fine-grained PAT — registers three read-only tools the LLM
# can use to walk your repos and report: `github_list_repos`,
# `github_repo_summary`, `github_recent_activity`. Generate at
# github.com/settings/tokens?type=beta with these scopes:
#   Contents: Read, Metadata: Read, Pull requests: Read, Issues: Read.
# The token goes straight to api.github.com — your local `gh auth`
# state is never touched.
GITHUB_TOKEN=

# === LLM provider routing (Phase B) ===
#
# The pipeline can route individual stages (triage, reflection, future
# main/compaction/etc.) through different providers. With no overrides,
# every stage uses the legacy SingleTurnClient path (Agent SDK or
# direct Anthropic) — identical to pre-Phase-B behavior.
#
# Each stage is overridden via `LLM_STAGE_<stage>="<provider>:<model>"`.
# Today only "near" is supported as a non-legacy provider; more land
# in later phases.
#
# Default provider for unspecified stages. "legacy" preserves current
# behavior; any other value still requires per-stage models to be set.
LLM_PROVIDER_DEFAULT=legacy
#
# Per-stage overrides. Format: "<provider>:<model>".
# Examples (uncomment to use):
#   LLM_STAGE_TRIAGE=near:claude-haiku-4-5
#   LLM_STAGE_REFLECTION=near:claude-haiku-4-5
LLM_STAGE_TRIAGE=
LLM_STAGE_REFLECTION=
#
# Main pipeline LLM. Empty = legacy LLMClient (Agent SDK or direct
# Anthropic). "near:<model>" routes through LLMSession + NEAR. The
# session handles streaming, tool round-trips, escalation — same
# surface as LLMClient, so nothing else needs to know which it is.
#   LLM_STAGE_MAIN=near:claude-sonnet-4-6
LLM_STAGE_MAIN=
#
# NEAR AI Cloud credentials. Required when any stage resolves to "near".
# Get a key at cloud.near.ai. Base URL defaults to the gateway; override
# only for testing or alternative endpoints.
NEAR_API_KEY=
# NEAR_BASE_URL=https://cloud-api.near.ai/v1

# Built-in Agent SDK tools the bot is allowed to call mid-conversation.
# Empty (default) = conversational-only, no shell/file/web access.
# Comma-separated list = those tools are advertised to the model AND
# `.claude/settings.local.json`'s permission patterns gate each call
# (same source of truth Claude Code uses — no duplicated config).
#
# Common shapes:
#   BOT_BUILTIN_TOOLS=WebFetch,WebSearch                      # read-only web
#   BOT_BUILTIN_TOOLS=Read,WebFetch,WebSearch                 # + read files
#   BOT_BUILTIN_TOOLS=Read,Write,Edit,Bash,WebFetch,WebSearch # full Claude Code surface
#
# IMPORTANT: enabling Bash/Write/Edit means a clever message *could*
# convince the model to do something destructive. settings.local.json
# patterns mitigate (your `Bash(curl *)` won't allow `Bash(rm -rf)`)
# but a permissive entry like `Bash(python3 *)` is effectively
# unrestricted. Audit your allowlist before flipping this on.
# BOT_BUILTIN_TOOLS=WebFetch,WebSearch

# Telegram (optional)
TELEGRAM_BOT_TOKEN=

# Paths (optional — defaults to ~/.microwaveos/)
# WORKSPACE_DIR=/path/to/workspace
# DATA_DIR=/path/to/data

# Claude CLI (optional — auto-detected)
# CLAUDE_CLI_PATH=/Users/you/.local/bin/claude

# ---------- Health module ----------
# Privacy-aware health Q&A pipeline. When enabled, triage classifies
# health-related messages, the router selects between the standard
# pipeline and (Phase 2) a BAA-covered LLM client, and the orchestrator
# fans out to authoritative sources (PubMed, MedlinePlus, etc.) for
# evidence-grounded responses with inline citations.
#
# Disabled by default. Flip HEALTH_MODULE_ENABLED to turn on; the rest
# inherit reasonable defaults.
# HEALTH_MODULE_ENABLED=true
# HEALTH_DEFAULT_LANGUAGE=en

# Retrieval source toggles. Phase 1 ships PubMed and MedlinePlus
# implementations; the others are reserved for later phases — flipping
# them on without an implementation registered is a no-op.
# HEALTH_RETRIEVAL_PUBMED=true
# HEALTH_RETRIEVAL_MEDLINEPLUS=true
# HEALTH_RETRIEVAL_OPENFDA=true        # Phase 3+
# HEALTH_RETRIEVAL_CDC=true            # Phase 3+
# HEALTH_RETRIEVAL_CLINICALTRIALS=true # Phase 3+
# HEALTH_RETRIEVAL_TIMEOUT_SECONDS=5.0
# HEALTH_RETRIEVAL_CACHE_TTL_HOURS=24

# Optional: NCBI E-utilities API key. Anonymous calls are capped at
# ~3 req/s; a key raises that to ~10 req/s. Personal-use volume is
# usually well under the anonymous cap.
# NCBI_API_KEY=

# BAA path (Phase 2 — declared for forward compatibility). If
# HEALTH_BAA_PROVIDER=none (default), personal health queries fall
# back to a safety message asking the user to rephrase or enable
# a BAA provider.
# HEALTH_BAA_PROVIDER=bedrock
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# HEALTH_BAA_MODEL_MAIN=anthropic.claude-sonnet-4-20250514-v1:0
# HEALTH_BAA_MODEL_ESCALATION=anthropic.claude-opus-4-7-20251101-v1:0

# Audit / encryption (Phase 2 wiring; safe to leave alone in Phase 1)
# HEALTH_AUDIT_RETENTION_DAYS=2555
# PHI_ENCRYPTION_KEY_SOURCE=keychain
