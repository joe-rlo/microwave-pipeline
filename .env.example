# Authentication
AUTH_MODE=max              # "max" (Agent SDK, no API key) or "api_key" (pay-as-you-go)
ANTHROPIC_API_KEY=         # Required if AUTH_MODE=api_key

# OpenAI (embeddings only)
OPENAI_API_KEY=sk-...

# Models
MODEL_MAIN=sonnet
MODEL_TRIAGE=haiku
MODEL_REFLECTION=haiku
MODEL_COMPACTION=sonnet
MODEL_ESCALATION=opus
ESCALATION_EFFORT=high     # low, medium, high, max

# Tools (optional). When the corresponding env var is set, the LLM
# gains the matching tool — registered as an in-process MCP server
# and exposed as `mcp__microwave__<tool-name>`. Without the key the
# tool isn't advertised to the model.

# Instacart Developer Platform — `instacart_create_cart` tool. Builds
# a Shop with Instacart link from a list of items; user finishes
# checkout in Instacart. Get a key at developer.instacart.com.
INSTACART_API_KEY=
# Optional: where to send the user after Instacart checkout.
# INSTACART_PARTNER_LINKBACK_URL=https://your.site/thanks

# Telegram (optional)
TELEGRAM_BOT_TOKEN=

# Paths (optional — defaults to ~/.microwaveos/)
# WORKSPACE_DIR=/path/to/workspace
# DATA_DIR=/path/to/data

# Claude CLI (optional — auto-detected)
# CLAUDE_CLI_PATH=/Users/you/.local/bin/claude

# ---------- Health module ----------
# Privacy-aware health Q&A pipeline. When enabled, triage classifies
# health-related messages, the router selects between the standard
# pipeline and (Phase 2) a BAA-covered LLM client, and the orchestrator
# fans out to authoritative sources (PubMed, MedlinePlus, etc.) for
# evidence-grounded responses with inline citations.
#
# Disabled by default. Flip HEALTH_MODULE_ENABLED to turn on; the rest
# inherit reasonable defaults.
# HEALTH_MODULE_ENABLED=true
# HEALTH_DEFAULT_LANGUAGE=en

# Retrieval source toggles. Phase 1 ships PubMed and MedlinePlus
# implementations; the others are reserved for later phases — flipping
# them on without an implementation registered is a no-op.
# HEALTH_RETRIEVAL_PUBMED=true
# HEALTH_RETRIEVAL_MEDLINEPLUS=true
# HEALTH_RETRIEVAL_OPENFDA=true        # Phase 3+
# HEALTH_RETRIEVAL_CDC=true            # Phase 3+
# HEALTH_RETRIEVAL_CLINICALTRIALS=true # Phase 3+
# HEALTH_RETRIEVAL_TIMEOUT_SECONDS=5.0
# HEALTH_RETRIEVAL_CACHE_TTL_HOURS=24

# Optional: NCBI E-utilities API key. Anonymous calls are capped at
# ~3 req/s; a key raises that to ~10 req/s. Personal-use volume is
# usually well under the anonymous cap.
# NCBI_API_KEY=

# BAA path (Phase 2 — declared for forward compatibility). If
# HEALTH_BAA_PROVIDER=none (default), personal health queries fall
# back to a safety message asking the user to rephrase or enable
# a BAA provider.
# HEALTH_BAA_PROVIDER=bedrock
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# HEALTH_BAA_MODEL_MAIN=anthropic.claude-sonnet-4-20250514-v1:0
# HEALTH_BAA_MODEL_ESCALATION=anthropic.claude-opus-4-7-20251101-v1:0

# Audit / encryption (Phase 2 wiring; safe to leave alone in Phase 1)
# HEALTH_AUDIT_RETENTION_DAYS=2555
# PHI_ENCRYPTION_KEY_SOURCE=keychain
