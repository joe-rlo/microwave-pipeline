      "fontSize": 11,
      "fontFamily": 5,
      "text": "\u2022 BAA lane now carries health_profile_* tools (allowlist in src/llm/factory.py). Original showed BAA as tool-less.",
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 9,
      "containerId": null,
      "originalText": "\u2022 BAA lane now carries health_profile_* tools (allowlist in src/llm/factory.py). Original showed BAA as tool-less.",
      "lineHeight": 1.25
    },
    {
      "id": "text_66",
      "type": "text",
      "x": 40,
      "y": 734,
      "width": 913,
      "height": 15,
      "angle": 0,
      "strokeColor": "#495057",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
