      "isDeleted": false,
      "boundElements": [],
      "updated": 1780023255476,
      "link": null,
      "locked": false,
      "fontSize": 11,
      "fontFamily": 5,
      "text": "\u2022 Assembly does NOT splice a [Health profile context] block. Profile reads happen on-demand via tool calls \u2014 cleaner than a pre-fetched slice-selector.",
      "textAlign": "left",
      "verticalAlign": "top",
      "baseline": 9,
      "containerId": null,
      "originalText": "\u2022 Assembly does NOT splice a [Health profile context] block. Profile reads happen on-demand via tool calls \u2014 cleaner than a pre-fetched slice-selector.",
      "lineHeight": 1.25
    },
