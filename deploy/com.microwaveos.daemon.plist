<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.microwaveos.daemon</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Library/Frameworks/Python.framework/Versions/3.13/bin/python3.13</string>
    <string>-m</string>
    <string>src.main</string>
    <string>--signal</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/Users/joe/Development/Skunk/MicrowaveOS-v2</string>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
    <key>Crashed</key>
    <true/>
  </dict>

  <key>ThrottleInterval</key>
  <integer>10</integer>

  <key>StandardOutPath</key>
  <string>/Users/joe/.microwaveos/daemon.out.log</string>

  <key>StandardErrorPath</key>
  <string>/Users/joe/.microwaveos/daemon.err.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
    <key>SCHEDULER_ENABLED</key>
    <string>true</string>
  </dict>
</dict>
</plist>
